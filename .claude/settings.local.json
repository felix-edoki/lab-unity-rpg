{
  "permissions": {
    "allow": [
      "Bash(git config *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git filter-branch -f --env-filter ' *)",
      "Bash(git stash *)",
      "Bash(xargs -n 1 git update-ref -d)",
      "Bash(gh issue *)"
    ]
